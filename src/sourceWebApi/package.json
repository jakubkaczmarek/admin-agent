{
  "name": "source-web-api",
  "version": "1.0.0",
  "description": "Node.js REST API for consumer reviews with MCP server",
  "main": "dist/server.js",
  "bin": {
    "consumer-reviews-mcp": "./dist/mcp-standalone.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "mcp": "tsx watch src/mcp-standalone.ts",
    "seed": "tsx src/seed.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "migrate:create": "db-migrate create",
    "migrate:up": "db-migrate up",
    "migrate:down": "db-migrate down",
    "migrate:status": "db-migrate status"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "cors": "^2.8.6",
    "csv-parse": "^5.5.3",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "mssql": "^12.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/mssql": "^9.1.9",
    "@types/node": "^20.10.0",
    "db-migrate": "^0.11.14",
    "db-migrate-mssql": "^2.1.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
